{
  "name": "ios-uploader",
  "version": "3.1.0",
  "description": "Easy to use, cross-platform tool to upload an iOS app to itunes-connect.",
  "keywords": [
    "ipa",
    "upload",
    "ios"
  ],
  "homepage": "https://github.com/simonnilsson/ios-uploader#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simonnilsson/ios-uploader.git"
  },
  "author": "Simon Nilsson <simon@nilsson.ml>",
  "license": "MIT",
  "main": "./lib/index.js",
  "type": "module",
  "bin": {
    "ios-uploader": "bin/index.js"
  },
  "scripts": {
    "start": "node bin/index.js",
    "build": "pkg . && node post-build.js",
    "lint": "eslint --max-warnings 0 ./bin/*.js ./lib/*.js ./test/*.js",
    "fix": "eslint --fix ./bin/*.js ./lib/*.js ./test/*.js",
    "test": "c8 mocha",
    "coverage": "c8 --reporter=lcov mocha"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "async": "^3.2.6",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "pretty-bytes": "^7.1.0",
    "simple-plist": "^1.3.1",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@yao-pkg/pkg": "^6.19.0",
    "c8": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "fetch-mock": "^12.6.0",
    "globals": "^17.6.0",
    "mocha": "^11.7.6",
    "resedit": "^3.0.2",
    "sinon": "^22.0.0",
    "svg-to-ico": "^1.1.1"
  },
  "files": [
    "bin/",
    "lib/"
  ],
  "pkg": {
    "scripts": [
      "./bin/**/*.js",
      "./lib/**/*.js"
    ],
    "assets": [],
    "targets": [
      "node20-win-x64",
      "node20-macos-x64",
      "node20-linux-x64",
      "node20-alpine-x64"
    ],
    "outputPath": "build",
    "compress": "Brotli"
  }
}
